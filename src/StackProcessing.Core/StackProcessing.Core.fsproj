<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
      <None Include="../../lib/spnth.dll" Condition="Exists('../../lib/spnth.dll')" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

    <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
      <None Include="../../lib/libspnth.so" Condition="Exists('../../lib/libspnth.so')" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

    <ItemGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
      <None Include="../../lib/libspnth.dylib" Condition="Exists('../../lib/libspnth.dylib')" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="BitMiracle.LibTiff.NET" Version="2.4.660" />
        <PackageReference Include="DIKU.Graph" Version="1.0.0" />
        <PackageReference Include="Plotly.NET" Version="5.1.0" />
        <PackageReference Include="PureHDF" Version="2.1.1" />
        <ProjectReference Include="../../../Zarr.NET/Zarr.NET.csproj" />
        <ProjectReference Include="../../../SharpFFTW/SharpFFTW/SharpFFTW.csproj" />
        <ProjectReference Include="../Chunk/Chunk.Core.fsproj" />
        <ProjectReference Include="../TinyLinAlg/TinyLinAlg.fsproj" />
        <ProjectReference Include="../SlimPipeline/SlimPipeline.fsproj" />
        <ProjectReference Include="../StackProcessing.Cost/StackProcessing.Cost.fsproj" />
    </ItemGroup>

    <ItemGroup>
        <Compile Include="StackCore.fs" />
        <Compile Include="StackMedian.fs" />
        <Compile Include="StackBinaryMorphology.fs" />
        <Compile Include="StackConvolve.fs" />
        <Compile Include="StackFFT.fs" />
        <Compile Include="StackConnectedComponents.fs" />
        <Compile Include="StackChunk.fs" />
        <Compile Include="StackOptimizer.fs" />
        <Compile Include="StackCharts.fs" />
        <Compile Include="StackIO.fs" />
        <Compile Include="StackPoints.fs" />
        <Compile Include="StackRegistration.fs" />
        <Compile Include="StackRansac.fs" />
        <Compile Include="StackManifest.fs" />
        <Compile Include="StackObjects.fs" />
        <Compile Include="StackMesh.fs" />
        <Compile Include="StackBias.fs" />
        <Compile Include="StackSerialSections.fs" />
        <Compile Include="StackAffineResampler.fs" />
    </ItemGroup>

</Project>
