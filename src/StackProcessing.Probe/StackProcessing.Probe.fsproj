<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../StackProcessing.RunSamples/RunSamples.fsproj" />
    <ProjectReference Include="../StackProcessing.Cost/StackProcessing.Cost.fsproj" />
    <ProjectReference Include="../StackProcessing/StackProcessing.fsproj" />
    <ProjectReference Include="../StackProcessing.Core/StackProcessing.Core.fsproj" />
    <ProjectReference Include="../Studio.Graph/Studio.Graph.fsproj" />
    <ProjectReference Include="../TinyLinAlg/TinyLinAlg.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Plotly.NET" Version="5.1.0" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="SimpleITKCSharp">
      <HintPath>../../lib/SimpleITKCSharpManaged.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
    <None Include="../../lib/SimpleITKCSharpNative.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>libSimpleITKCSharpNative.dll</TargetPath>
    </None>
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
    <None Include="../../lib/libSimpleITKCSharpNative.so" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
    <None Include="../../lib/libSimpleITKCSharpNative.dylib" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Analysis.fs" />
    <Compile Include="Selection.fs" />
    <Compile Include="Probing.fs" />
    <Compile Include="ProbingReport.fs" />
    <Compile Include="Calibration.fs" />
    <Compile Include="BottomUpCalibration.fs" />
    <Compile Include="LocalUpdate.fs" />
    <Compile Include="Fit.fs" />
    <Compile Include="Collect.fs" />
    <Compile Include="Inspect.fs" />
    <Compile Include="LadderClimb.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

</Project>
