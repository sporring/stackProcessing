<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ne="clr-namespace:NodeEditor.Controls;assembly=NodeEditorAvalonia"
             xmlns:vm="using:Studio.ViewModels"
             xmlns:models="using:Studio.Models"
             xmlns:graph="using:Graph"
             x:Class="Studio.Views.MainView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Styles>
        <Style Selector="ne|Connector">
            <Setter Property="Stroke" Value="#D32F2F" />
            <Setter Property="StrokeThickness" Value="3" />
            <Setter Property="Fill" Value="Transparent" />
        </Style>

        <Style Selector="ne|Pin">
            <Setter Property="Template">
                <ControlTemplate TargetType="ne:Pin">
                    <Polygon Width="{TemplateBinding Width}"
                             Height="{TemplateBinding Height}"
                             Points="0,0 14,7 0,14"
                             Fill="#FFFFFF"
                             Stroke="#111111"
                             StrokeThickness="2" />
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="ne|Pin[Id=__ParameterInput]">
            <Setter Property="Template">
                <ControlTemplate TargetType="ne:Pin">
                    <Polygon Width="{TemplateBinding Width}"
                             Height="{TemplateBinding Height}"
                             Points="0,0 14,0 7,14"
                             Fill="#8A5A22"
                             Stroke="#111111"
                             StrokeThickness="2" />
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="ne|Pin[Id=__ScalarOutput]">
            <Setter Property="Template">
                <ControlTemplate TargetType="ne:Pin">
                    <Polygon Width="{TemplateBinding Width}"
                             Height="{TemplateBinding Height}"
                             Points="0,0 14,0 7,14"
                             Fill="#8A5A22"
                             Stroke="#111111"
                             StrokeThickness="2" />
                </ControlTemplate>
            </Setter>
        </Style>
    </UserControl.Styles>

    <UserControl.DataTemplates>
        <DataTemplate x:DataType="graph:Function">
            <Border Margin="0,0,0,6"
                    Padding="8,6"
                    HorizontalAlignment="Stretch"
                    Background="#FFFFFF"
                    BorderBrush="#D7DDE5"
                    BorderThickness="1"
                    CornerRadius="4"
                    Tag="{Binding Id}"
                    PointerPressed="PaletteElementPointerPressed">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding DisplayName}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#102A43" />
                    <TextBlock Text="{Binding Description}"
                               FontSize="10"
                               Foreground="#52616B"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:DataType="models:PaletteGroupViewModel">
            <Expander Header="{Binding Title}"
                      IsExpanded="{Binding IsExpanded, Mode=OneWay}"
                      HorizontalAlignment="Stretch"
                      Margin="0,0,0,6">
                <ItemsControl ItemsSource="{Binding Functions}"
                              HorizontalAlignment="Stretch" />
            </Expander>
        </DataTemplate>

        <DataTemplate DataType="models:PipelineNodeContent">
            <Border Width="110"
                    Height="48"
                    Background="{Binding State.NodeBackground}"
                    BorderBrush="{Binding State.NodeBorderBrush}"
                    BorderThickness="2"
                    Opacity="{Binding State.NodeOpacity}"
                    CornerRadius="6">
                <TextBlock Text="{Binding Label}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="11"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Foreground="#102A43" />
            </Border>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Grid RowDefinitions="Auto,*,220"
          ColumnDefinitions="260,*,340"
          Background="#FFFFFF">

        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Background="#F4F6F8"
                BorderBrush="#D7DDE5"
                BorderThickness="0,0,0,1"
                Padding="10">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Width="76"
                            Click="SaveGraphClicked"
                            Content="Save" />
                    <Button Width="76"
                            Click="LoadGraphClicked"
                            Content="Load" />
                    <Button Width="76"
                            Click="ClearGraphClicked"
                            Content="Clear" />
                    <Button Width="76"
                            Command="{Binding RunCommand}"
                            Content="Run" />
                </StackPanel>

                <TextBlock Text="StackProcessing Studio"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#102A43" />
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#FAFBFC"
                BorderBrush="#D7DDE5"
                BorderThickness="0,0,1,0"
                Padding="10">
            <Grid RowDefinitions="Auto,Auto,*">
                <TextBlock Text="Functions"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <TextBox Grid.Row="1"
                         Watermark="Search functions"
                         Text="{Binding PaletteSearch, Mode=TwoWay}"
                         Margin="0,0,0,10"
                         MinHeight="30" />

                <ScrollViewer Grid.Row="2">
                    <ItemsControl ItemsSource="{Binding PaletteGroups}"
                                  HorizontalAlignment="Stretch" />
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid x:Name="GraphHost"
              Grid.Row="1"
              Grid.Column="1"
              ClipToBounds="True"
              Background="#FFFFFF"
              DragDrop.AllowDrop="True"
              DragDrop.DragOver="PipelineEditorDragOver"
              DragDrop.Drop="PipelineEditorDrop">
            <ne:Editor x:Name="PipelineEditor"
                       DrawingSource="{Binding Editor.Drawing}"
                       DragDrop.AllowDrop="True"
                       DragDrop.DragOver="PipelineEditorDragOver"
                       DragDrop.Drop="PipelineEditorDrop"
                       Background="#FFFFFF" />

            <Canvas IsHitTestVisible="False">
                <Line x:Name="ConnectionPreview"
                      IsVisible="False"
                      Stroke="#D32F2F"
                      StrokeThickness="3"
                      StartPoint="0,0"
                      EndPoint="0,0" />
            </Canvas>

            <Border x:Name="GraphTrash"
                    Width="86"
                    Height="42"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,12,12"
                    Background="#FFF1F0"
                    BorderBrush="#C62828"
                    BorderThickness="1"
                    CornerRadius="6"
                    DragDrop.AllowDrop="True"
                    DragDrop.DragOver="TrashDragOver"
                    DragDrop.Drop="TrashDrop">
                <TextBlock Text="Trash"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#8E1B1B" />
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Grid.Column="2"
                Background="#FAFBFC"
                BorderBrush="#D7DDE5"
                BorderThickness="1,0,0,0"
                Padding="10">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Parameters"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding SelectedNode.State.Parameters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:PipelineParameterViewModel">
                                <Grid ColumnDefinitions="92,72,*"
                                      Margin="0,0,0,10">
                                    <TextBlock Text="{Binding Label}"
                                               VerticalAlignment="Center"
                                               FontSize="12" />
                                    <CheckBox Grid.Column="1"
                                              Content="Graph"
                                              IsChecked="{Binding UseInput, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              FontSize="11" />
                                    <TextBox Grid.Column="2"
                                             Text="{Binding Value, Mode=TwoWay}"
                                             IsEnabled="{Binding IsValueEditable}"
                                             MinHeight="30" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="3"
                Background="#FFFFFF"
                BorderBrush="#D7DDE5"
                BorderThickness="0,1,0,0"
                Padding="10">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Generated F#"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <TextBox Grid.Row="1"
                         Text="{Binding GeneratedProgram}"
                         FontFamily="Consolas, Menlo, monospace"
                         FontSize="13"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         Background="#FFFFFF"
                         BorderBrush="#D7DDE5" />
            </Grid>
        </Border>

        <Canvas x:Name="PaletteDragOverlay"
                Grid.RowSpan="3"
                Grid.ColumnSpan="3"
                Panel.ZIndex="1000"
                IsHitTestVisible="False">
            <Border x:Name="PaletteDragPreview"
                    Width="110"
                    Height="48"
                    IsVisible="False"
                    Background="#FFF8E1"
                    BorderBrush="#F2A900"
                    BorderThickness="2"
                    Opacity="0.86"
                    CornerRadius="6">
                <TextBlock x:Name="PaletteDragPreviewLabel"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="11"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Foreground="#102A43" />
            </Border>
        </Canvas>
    </Grid>
</UserControl>
