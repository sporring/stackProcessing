<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ne="clr-namespace:NodeEditor.Controls;assembly=NodeEditorAvalonia"
             xmlns:vm="using:Studio.ViewModels"
             xmlns:models="using:Studio.Models"
             x:Class="Studio.Views.MainView"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.DataTemplates>
        <DataTemplate DataType="models:PipelineNodeContent">
            <Border Width="110"
                    Height="48"
                    Background="#EAF3FF"
                    BorderBrush="#2F80ED"
                    BorderThickness="2"
                    CornerRadius="6">
                <TextBlock Text="{Binding Label}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="11"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Foreground="#102A43" />
            </Border>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Grid RowDefinitions="Auto,*,220"
          ColumnDefinitions="*,340"
          Background="#FFFFFF">

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="#F4F6F8"
                BorderBrush="#D7DDE5"
                BorderThickness="0,0,0,1"
                Padding="10">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Width="76"
                        Command="{Binding RunCommand}"
                        Content="Run" />

                <WrapPanel Orientation="Horizontal">
                    <Button Margin="0,0,6,0" Command="{Binding AddSourceCommand}" Content="+ source" Tag="Source" PointerMoved="PaletteElementPointerMoved" />
                    <Button Margin="0,0,6,0" Command="{Binding AddReadCommand}" Content="+ read" Tag="Read" PointerMoved="PaletteElementPointerMoved" />
                    <Button Margin="0,0,6,0" Command="{Binding AddGaussianCommand}" Content="+ gaussian" Tag="DiscreteGaussian" PointerMoved="PaletteElementPointerMoved" />
                    <Button Margin="0,0,6,0" Command="{Binding AddCastCommand}" Content="+ cast" Tag="Cast" PointerMoved="PaletteElementPointerMoved" />
                    <Button Margin="0,0,6,0" Command="{Binding AddWriteCommand}" Content="+ write" Tag="Write" PointerMoved="PaletteElementPointerMoved" />
                    <Button Margin="0,0,6,0" Command="{Binding AddSinkCommand}" Content="+ sink" Tag="Sink" PointerMoved="PaletteElementPointerMoved" />
                    <Button Command="{Binding DeleteSelectedCommand}"
                            IsEnabled="{Binding HasSelectedElement}"
                            Content="Delete" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <Grid x:Name="GraphHost"
              Grid.Row="1"
              Grid.Column="0"
              ClipToBounds="True"
              Background="#FFFFFF"
              DragDrop.AllowDrop="True"
              DragDrop.DragOver="PipelineEditorDragOver"
              DragDrop.Drop="PipelineEditorDrop">
            <ne:Editor x:Name="PipelineEditor"
                       DrawingSource="{Binding Editor.Drawing}"
                       DragDrop.AllowDrop="True"
                       DragDrop.DragOver="PipelineEditorDragOver"
                       DragDrop.Drop="PipelineEditorDrop"
                       Background="#FFFFFF" />

            <Canvas IsHitTestVisible="False">
                <Line x:Name="ConnectionPreview"
                      IsVisible="False"
                      Stroke="#D32F2F"
                      StrokeThickness="3"
                      StartPoint="0,0"
                      EndPoint="0,0" />
            </Canvas>

            <Border x:Name="GraphTrash"
                    Width="86"
                    Height="42"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,12,12"
                    Background="#FFF1F0"
                    BorderBrush="#C62828"
                    BorderThickness="1"
                    CornerRadius="6"
                    DragDrop.AllowDrop="True"
                    DragDrop.DragOver="TrashDragOver"
                    DragDrop.Drop="TrashDrop">
                <TextBlock Text="Trash"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#8E1B1B" />
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Grid.Column="1"
                Background="#FAFBFC"
                BorderBrush="#D7DDE5"
                BorderThickness="1,0,0,0"
                Padding="10">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Parameters"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding SelectedElement.Parameters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:PipelineParameterViewModel">
                                <Grid ColumnDefinitions="120,*"
                                      Margin="0,0,0,10">
                                    <TextBlock Text="{Binding Label}"
                                               VerticalAlignment="Center"
                                               FontSize="12" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Value, Mode=TwoWay}"
                                             MinHeight="30" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Background="#FFFFFF"
                BorderBrush="#D7DDE5"
                BorderThickness="0,1,0,0"
                Padding="10">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Generated F#"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <TextBox Grid.Row="1"
                         Text="{Binding GeneratedProgram}"
                         FontFamily="Consolas, Menlo, monospace"
                         FontSize="13"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         Background="#FFFFFF"
                         BorderBrush="#D7DDE5" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
