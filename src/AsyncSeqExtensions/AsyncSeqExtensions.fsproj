<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- Signature generation can be re-enabled by setting EnableSigGeneration=true. -->
  <PropertyGroup Condition="'$(EnableSigGeneration)'=='true'">
    <SigFile>$(MSBuildThisFileDirectory)AsyncSeqExtensions.fsi</SigFile>
  </PropertyGroup>
  <PropertyGroup Condition="'$(EnableSigGeneration)'=='true' and '$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <DefineConstants>TRACE</DefineConstants>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <OtherFlags>--sig:"$(SigFile)"</OtherFlags>
  </PropertyGroup>
  <Target Name="CleanTextFile" AfterTargets="Build" Condition="'$(EnableSigGeneration)'=='true'">
    <Exec Command="tmp='$(SigFile).tmp.'$$; grep -v '^[[:space:]]*$' '$(SigFile)' &gt; &quot;$tmp&quot; &amp;&amp; mv &quot;$tmp&quot; '$(SigFile)'"/>
  </Target>

  <ItemGroup>
    <Compile Include="AsyncSeqExtensions.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Control.AsyncSeq" Version="4.15.0" />
  </ItemGroup>

</Project>
