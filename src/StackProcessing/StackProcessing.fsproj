<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <!-- Signature generation can be re-enabled by setting EnableSigGeneration=true. -->
    <PropertyGroup Condition="'$(EnableSigGeneration)'=='true'">
        <SigFile>$(MSBuildThisFileDirectory)StackProcessing.fsi</SigFile>
    </PropertyGroup>

    <PropertyGroup Condition="'$(EnableSigGeneration)'=='true' and '$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
        <DefineConstants>TRACE</DefineConstants>
        <PlatformTarget>AnyCPU</PlatformTarget>
        <OtherFlags>--sig:"$(SigFile)"</OtherFlags>
    </PropertyGroup>
<!--
    <Target Name="CleanTextFile" AfterTargets="Build">
        <Exec Command="tmp='$(SigFile).tmp.'$$; grep -v '^[[:space:]]*$' '$(SigFile)' &gt; &quot;$tmp&quot; &amp;&amp; mv &quot;$tmp&quot; '$(SigFile)'"/>
    </Target>
-->

    <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
      <None Include="../../lib/lowlevel.dll" Condition="Exists('../../lib/lowlevel.dll')" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>
    
    <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
      <None Include="../../lib/liblowlevel.so" Condition="Exists('../../lib/liblowlevel.so')" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

    <ItemGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
      <None Include="../../lib/liblowlevel.dylib" Condition="Exists('../../lib/liblowlevel.dylib')" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>
    
    <ItemGroup>
        <ProjectReference Include="../Chunk/Chunk.Core.fsproj" />
        <ProjectReference Include="../SlimPipeline/SlimPipeline.fsproj" />
        <ProjectReference Include="../StackProcessing.Core/StackProcessing.Core.fsproj" />
<!--
        <ProjectReference Include="../../diku-graph/graph/graph.fsproj" />
-->
    </ItemGroup>

    <ItemGroup>
        <Compile Include="StackProcessing.fs" />
    </ItemGroup>

</Project>
