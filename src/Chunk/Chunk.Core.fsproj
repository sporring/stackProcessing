<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../../lib/spnth.dll" Condition="$([MSBuild]::IsOSPlatform('Windows')) and Exists('../../lib/spnth.dll')" CopyToOutputDirectory="PreserveNewest" />
    <None Include="../../lib/libspnth.so" Condition="$([MSBuild]::IsOSPlatform('Linux')) and Exists('../../lib/libspnth.so')" CopyToOutputDirectory="PreserveNewest" />
    <None Include="../../lib/libspnth.dylib" Condition="$([MSBuild]::IsOSPlatform('OSX')) and Exists('../../lib/libspnth.dylib')" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Chunk.fs" />
    <Compile Include="ChunkFunctions.fs" />
  </ItemGroup>

</Project>
